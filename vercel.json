{
  "version": 2,
  "builds": [
    {
      "src": "api/data.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/data",   "dest": "/api/data.py" },
    { "src": "/api/stream", "dest": "/api/data.py" },
    { "src": "/api/unlock", "dest": "/api/data.py" },
    { "src": "/api/logout", "dest": "/api/data.py" },
    { "src": "/(.*)",       "dest": "/index.html"  }
  ]
}
