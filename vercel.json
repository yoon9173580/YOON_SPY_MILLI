{
  "builds": [
    {
      "src": "api/data.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/data",
      "dest": "/api/data.py"
    },
    {
      "src": "/api/unlock",
      "dest": "/api/data.py"
    }
  ]
}
