APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
FLASHALPHA_API_KEY=

# Upstash Redis — persistent portfolio & trade log storage
# Either naming convention works (Upstash standard or Vercel KV):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=       (alternative — Vercel KV auto-injected name)
# KV_REST_API_TOKEN=     (alternative — Vercel KV auto-injected name)

# Optional fallback demo store (unreliable for production)
# PORTFOLIO_REST_URL=https://api.restful-api.dev/objects/...

# === Google SSO Security (replaces legacy UNLOCK_PASSWORD) ===
# GOOGLE_CLIENT_ID= your-app-xxx.apps.googleusercontent.com   (from Google Cloud Console > OAuth)
# ALLOWED_EMAILS=yoongun64@gmail.com,yourname@domain.com     (comma separated)
# (UNLOCK_PASSWORD / APP_SECRET_KEY no longer used for auth)

# === Proprietary Signal Grade Thresholds (for code access security) ===
# These control when signals are classified as STRONG / MODERATE / WEAK.
# Move production values out of source code into Vercel env vars.
GRADE_STRONG=90
GRADE_MODERATE=75
GRADE_WEAK=60
